# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# LinkedIn credentials — used by the browser login fallback in tools/playwright_actions.py.
# Prefer logging in manually via the "Login to LinkedIn" button in the UI rather than storing here.
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# Optional: Google API key (e.g. for non-OAuth Google services).
GOOGLE_API_KEY=

# Default Ollama model used for match scoring, form-fill LLM, and the self-heal analyst.
# See tools/llm_models.py for the resolution logic. Alias of REASONING_MODEL.
DEFAULT_LLM_MODEL=gpt-oss:120b-cloud

# Ollama base URL. In Docker, the compose file sets host.docker.internal.
OLLAMA_BASE_URL=http://localhost:11434

# ── Agentic mode (planner-executor loop) ──────────────────────────────────────
# AGENTIC=true switches from the legacy fixed graph to the GPT-OSS planner that
# owns control flow via tool-calling and self-heals via the Qwen3 CodeAgent.
AGENTIC=false
# Two-role model layer (tools/model_router.py). Both env-configurable.
REASONING_MODEL=gpt-oss:120b-cloud      # planning, evaluation, outreach (non-coding)
CODING_MODEL=qwen3-coder:480b-cloud     # selectors, scrapers, scripts, debugging
# Require human approval of generated code before it is hot-loaded (recommended).
SELF_CODING_REQUIRE_APPROVAL=true
# Max planner turns per run before the loop ends.
AGENTIC_MAX_ITERATIONS=60

# Optional caps (defaults shown).
# MAX_APPLICATIONS_PER_DAY=50
# MAX_CONNECTIONS_PER_DAY=30
# MAX_ITERATIONS=50
# MAX_WATCH_ITERATIONS=1000
# APPLY_THRESHOLD=70
# OUTREACH_THRESHOLD=60

# Optional applicant override values used by tools/apply_actions.py if profile_overrides + CV are missing.
# APPLICANT_FIRST_NAME=
# APPLICANT_LAST_NAME=
# APPLICANT_EMAIL=
# APPLICANT_PHONE=
# APPLICANT_CITY=
# APPLICANT_LINKEDIN=
# APPLICANT_GITHUB=
# APPLICANT_PORTFOLIO=
# APPLICANT_YEARS_EXP=
# APPLICANT_SALARY=
# APPLICANT_NOTICE=
